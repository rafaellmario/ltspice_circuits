********************************************************************
* MODEL: ccm1
* Application: two switch PWM converters
* LIMITATIONS: Ideal switches, CCM only, no transformer
********************************************************************

* Parameters: none
********************************************************************
* Nodes:
* 1: transistor +(D)
* 2: transistor -(S)
* 3: diode cathode (K)
* 4: diode anode (A)
* 5: duty ratio (duty)
********************************************************************

.SUBCKT ccm1 1 2 3 4 5
	Et 1 2 value = {(1-v(5))*v(3,4)/v(5)}
	Gd 4 3 value = {(1-v(5))*i(Et)/v(5)}
.ENDS

********************************************************************
